[sub_resource type="LabelSettings" id="LabelSettings_qd7ch"]
font_size = 100

[sub_resource type="GDScript" id="GDScript_3prj8"]
script/source = "extends Label

@export var fontflie:FontFile

func _ready() -> void:
	var fontset = self.label_settings
	fontset.font = fontflie
	
	var b = get_parent() as Button
	if b:
		fontset.font_size = int(b.size.y * 0.5)
		self.global_position.y = b.position.y + b.size.y*0.225
		self.global_position.x = b.position.x + b.size.x*0.5
		self.text = b.texts
	
"

